# Neon PostgreSQL connection strings
# Get these from your Neon dashboard: https://neon.tech
# DATABASE_URL is the pooled connection (PgBouncer) - used by the app at runtime
# DIRECT_URL is the direct connection - used by Prisma for migrations and db push
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT secret for auth - change this to a strong random string
JWT_SECRET="your-jwt-secret-here"
